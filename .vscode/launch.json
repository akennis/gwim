    "version": "0.2.0",
    "configurations": [
        {
            "name": "machine min-win-server",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/examples/min-win-server.go",
            "args": [
                "-server-addr",
                "0.0.0.0:8443",
                "-cert-subject",
                "",
                "-ldap-address",
                "DC1.ouboces.local:636",
                "-ldap-users-dn",
                "OU=OUBOCES Users, OU=OUBOCES, DC=ouboces, DC=local",
                "-ldap-service-account-spn",
                "ldap/DC1.ouboces.local"
            ]
        },
        {
